<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.scene.image.ImageView?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.effect.Blend?>
<AnchorPane prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controller.HomeController">
    <children>
        <ImageView fitHeight="600.0" fitWidth="900.0" pickOnBounds="true">
            <image>
                <Image url="@../assets/images/backgrounds/home2.jpg" />
            </image>
        </ImageView>
        <Text fill="WHITE" layoutX="267.0" layoutY="93.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Dừng lại một chút không có nghĩa là tụt hậu">
            <font>
                <Font size="18.0" />
            </font>
        </Text>
        <Text fill="WHITE" layoutX="358.0" layoutY="118.0" strokeType="OUTSIDE" strokeWidth="0.0" text="mà là để bước xa hơn">
            <font>
                <Font size="18.0" />
            </font>
        </Text>

        <AnchorPane layoutX="474.0" layoutY="142.0" onMouseClicked="#showTodoList" prefHeight="194.0" prefWidth="208.0" style="-fx-background-color: rgba(10,-50,10,0.56); -fx-background-radius: 20;">
            <children>
                <Text fill="WHITE" layoutX="10.0" layoutY="37.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Hoạt động trong ngày" wrappingWidth="192.0">
                    <font>
                        <Font name="Corbel Bold Italic" size="20.0" />
                    </font>
                </Text>
                <Button layoutX="150.0" layoutY="63.0" mnemonicParsing="false" prefHeight="34.0" prefWidth="34.0" style="-fx-background-color: #1bbf20;" text="+" textFill="#f5f5f5" />
                <ImageView fitHeight="113.0" fitWidth="150.0" layoutX="31.0" layoutY="80.0" pickOnBounds="true">
                    <image>
                        <Image url="@../assets/images/icon/list-removebg-preview (1).png" />
                    </image>
                </ImageView>
                <Label layoutX="31.0" layoutY="63.0" prefHeight="34.0" prefWidth="119.0" style="-fx-background-color: #5e5e5e;" text="   Thêm nhiệm vụ..." textFill="#d3d3d3" />
            </children>
            <cursor>
                <Cursor fx:constant="HAND" />
            </cursor></AnchorPane>
        <Label layoutX="315.0" layoutY="14.0" text="CODEMATE" textFill="#8598e1">
            <font>
                <Font name="Bodoni MT Black" size="40.0" />
            </font>
            <effect>
                <Blend/>
            </effect>
        </Label>
        <Label fx:id="logout" layoutX="14.0" layoutY="14.0" onMouseClicked="#logout" prefHeight="31.0" prefWidth="97.0" style="-fx-background-color: #03c326; -fx-background-radius: 10;" text=" Đăng xuất" textAlignment="CENTER" textFill="WHITE">
            <font>
                <Font name="System Bold" size="17.0" />
            </font>
        </Label>
    </children>
</AnchorPane>
